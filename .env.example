# Copy to .env and fill in values. See src/lib/env.ts for validation rules.

PORT=3001
MONGODB_URI=mongodb+srv://...
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
FIREBASE_PROJECT_ID=
# Optional: path to service account JSON file, or use your deployment’s secret injection
# FIREBASE_SERVICE_ACCOUNT_KEY=
REVENUECAT_WEBHOOK_SECRET=
SESSION_SECRET=replace-with-at-least-32-random-characters

# Optional — AI Recipe Helper (POST /api/ai/*) returns 503 when unset
# ANTHROPIC_API_KEY=
