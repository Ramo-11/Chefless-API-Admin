<% var pageTitle = 'Early Access'; %>
<% var page = 'early-access'; %>

<div class="page-header">
  <div>
    <h1>Early Access</h1>
    <p class="page-subtitle">
      <%= totalContacts.toLocaleString() %> contacts ·
      <%= counts.subscribed.toLocaleString() %> subscribed ·
      <%= counts.unsubscribed.toLocaleString() %> unsubscribed
    </p>
  </div>
</div>

<p class="text-muted text-sm" style="margin-top:-.5rem;margin-bottom:1.25rem;">
  This is the early-signup mailing list collected from the Google Form. It is
  completely separate from app accounts &mdash; nothing here touches Chefless users or their data.
</p>

<!-- ── Import CSV ──────────────────────────────────────────────── -->
<div class="card" style="margin-bottom:1.25rem;">
  <div class="card-header">
    <h2><i class="fas fa-file-csv"></i> Import contacts</h2>
  </div>
  <div class="card-body">
    <p class="text-muted text-sm" style="margin-top:0;">
      Upload the Google Form CSV export (or paste its contents). Columns are matched
      automatically. Contacts already on the list are updated by email &mdash; nothing is duplicated.
    </p>
    <div class="form-group">
      <label for="csv-file">CSV file</label>
      <input type="file" id="csv-file" accept=".csv,text/csv">
    </div>
    <div class="form-group">
      <label for="csv-text">…or paste CSV content</label>
      <textarea id="csv-text" rows="5" placeholder="Timestamp,First Name:,Last Name:,Email Address:,…" style="font-family:monospace;font-size:12px;"></textarea>
    </div>
    <div style="display:flex;justify-content:flex-end;">
      <button class="btn btn-primary btn-sm" id="import-btn" onclick="importCsv()">
        <i class="fas fa-upload"></i> Import contacts
      </button>
    </div>
  </div>
</div>

<!-- ── Compose & send ──────────────────────────────────────────── -->
<div class="card" style="margin-bottom:1.25rem;">
  <div class="card-header">
    <h2><i class="fas fa-paper-plane"></i> Compose campaign</h2>
  </div>
  <div class="card-body">
    <p class="text-muted text-sm" style="margin-top:0;">
      Use <code>{{firstName}}</code> anywhere in the subject or message to personalize it.
      Every email includes a Chefless header and an unsubscribe link automatically.
    </p>
    <div class="form-group">
      <label for="campaign-subject">Subject</label>
      <input type="text" id="campaign-subject" maxlength="200" placeholder="Chefless is live, {{firstName}} 🎉">
    </div>
    <div class="form-group">
      <label for="campaign-body">Message</label>
      <textarea id="campaign-body" rows="10" maxlength="20000" placeholder="Hi {{firstName}},&#10;&#10;The day is finally here — Chefless is now on the App Store…&#10;&#10;Leave a blank line between paragraphs."></textarea>
    </div>
    <div class="form-group">
      <label>Send to</label>
      <label style="display:flex;align-items:center;gap:.5rem;font-weight:normal;cursor:pointer;">
        <input type="radio" name="audience" value="all" checked onchange="updateAudienceUI()">
        All subscribed contacts (<%= readyToSendCount.toLocaleString() %><% if (needsReviewCount > 0) { %>, <%= needsReviewCount %> flagged address<%= needsReviewCount === 1 ? '' : 'es' %> skipped<% } %>)
      </label>
      <label style="display:flex;align-items:center;gap:.5rem;font-weight:normal;cursor:pointer;margin-top:.35rem;">
        <input type="radio" name="audience" value="selected" id="audience-selected" onchange="updateAudienceUI()">
        Only selected contacts (<span id="selected-count">0</span> picked in the table below)
      </label>
    </div>
    <div style="display:flex;justify-content:flex-end;gap:.5rem;">
      <button class="btn btn-secondary btn-sm" onclick="openPreviewModal()">
        <i class="fas fa-eye"></i> Preview email
      </button>
      <button class="btn btn-primary btn-sm" onclick="openSendModal()">
        <i class="fas fa-paper-plane"></i> Review &amp; send
      </button>
    </div>
  </div>
</div>

<!-- ── Contacts ────────────────────────────────────────────────── -->
<div class="card" style="margin-bottom:1.25rem;">
  <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
    <h2>
      <i class="fas fa-address-book"></i> Contacts
      <span class="badge badge-default" style="margin-left:.35rem;"><%= pagination.totalItems.toLocaleString() %></span>
    </h2>
    <button class="btn btn-primary btn-sm" onclick="openModal('add-contact-modal')">
      <i class="fas fa-user-plus"></i> Add someone
    </button>
  </div>
  <div class="card-body" style="padding-bottom:0;">
    <div class="toolbar" style="margin-bottom:.5rem;">
      <form action="/admin/early-access" method="GET" class="toolbar-search">
        <input type="text" name="search" value="<%= search %>" placeholder="Search name or email…">
        <input type="hidden" name="status" value="<%= statusFilter %>">
        <button type="submit" class="btn btn-primary btn-sm">Search</button>
        <% if (search) { %>
          <a href="/admin/early-access?status=<%= statusFilter %>" class="btn btn-secondary btn-sm">Clear</a>
        <% } %>
      </form>
      <div class="toolbar-filters">
        <a href="/admin/early-access?status=all<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter-chip <%= statusFilter === 'all' ? 'active' : '' %>">All</a>
        <a href="/admin/early-access?status=subscribed<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter-chip <%= statusFilter === 'subscribed' ? 'active' : '' %>">Subscribed</a>
        <a href="/admin/early-access?status=unsubscribed<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter-chip <%= statusFilter === 'unsubscribed' ? 'active' : '' %>">Unsubscribed</a>
        <a href="/admin/early-access?status=bounced<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter-chip <%= statusFilter === 'bounced' ? 'active' : '' %>">Bounced</a>
        <a href="/admin/early-access?status=needsReview<%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="filter-chip <%= statusFilter === 'needsReview' ? 'active' : '' %>" style="<%= needsReviewCount > 0 ? 'color:#b45309;' : '' %>">
          <i class="fas fa-triangle-exclamation"></i> Needs review
          <% if (needsReviewCount > 0) { %><span class="filter-count"><%= needsReviewCount %></span><% } %>
        </a>
      </div>
    </div>
    <div id="selection-bar" class="text-sm" style="display:none;align-items:center;gap:.75rem;padding:.5rem .25rem;">
      <strong><span id="selection-bar-count">0</span> contact(s) selected</strong>
      <span class="text-muted">— selection is kept as you search and page through the list.</span>
      <button class="btn btn-secondary btn-sm" onclick="clearSelection()">Clear selection</button>
    </div>
  </div>
  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th style="width:32px;">
            <input type="checkbox" id="select-all" onchange="toggleSelectAll(this)" aria-label="Select all on this page">
          </th>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>From / Lives</th>
          <th>Signed up</th>
          <th>Emailed</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% contacts.forEach(function(c) { %>
        <tr id="contact-row-<%= c._id %>">
          <td>
            <% if (c.status === 'subscribed') { %>
              <input type="checkbox" class="contact-check" value="<%= c._id %>" onchange="onContactCheck(this)" aria-label="Select contact">
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td><strong><%= [c.firstName, c.lastName].filter(Boolean).join(' ') || '—' %></strong></td>
          <td class="text-sm">
            <% if (c.needsReview) { %>
              <span title="This email doesn't look valid — open Edit to fix it. Sends will skip this contact until then." style="color:#b45309;margin-right:.25rem;">
                <i class="fas fa-triangle-exclamation"></i>
              </span>
            <% } %>
            <%= c.email %>
          </td>
          <td class="text-muted text-sm"><%= c.phone || '—' %></td>
          <td class="text-muted text-sm">
            <%= c.ethnicity || '—' %><% if (c.country) { %> · <%= c.country %><% } %>
          </td>
          <td class="text-muted text-sm">
            <%= c.signedUpAt ? new Date(c.signedUpAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '—' %>
          </td>
          <td class="text-muted text-sm">
            <% if (c.emailsSent && c.emailsSent > 0) { %>
              <%= c.emailsSent %>&times;<% if (c.lastEmailedAt) { %><br><span style="font-size:11px;">last <%= new Date(c.lastEmailedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %></span><% } %>
            <% } else { %>
              —
            <% } %>
          </td>
          <td>
            <%
              var statusClass = 'badge-success';
              if (c.status === 'unsubscribed') statusClass = 'badge-default';
              else if (c.status === 'bounced') statusClass = 'badge-danger';
            %>
            <span class="badge <%= statusClass %>"><%= c.status %></span>
          </td>
          <td>
            <div class="action-buttons">
              <button class="btn btn-sm btn-secondary"
                data-id="<%= c._id %>"
                data-first="<%= c.firstName || '' %>"
                data-last="<%= c.lastName || '' %>"
                data-email="<%= c.email %>"
                data-phone="<%= c.phone || '' %>"
                onclick="openEditContact(this)" aria-label="Edit contact">
                <i class="fas fa-pen"></i>
              </button>
              <% if (c.status === 'bounced') { %>
                <span class="text-muted text-sm">—</span>
              <% } else { %>
                <button class="btn btn-sm btn-secondary" onclick="toggleContact('<%= c._id %>')" aria-label="Toggle subscription">
                  <%= c.status === 'subscribed' ? 'Unsubscribe' : 'Resubscribe' %>
                </button>
              <% } %>
              <button class="btn btn-sm btn-danger-outline" onclick="deleteContact('<%= c._id %>', '<%= c.email.replace(/'/g, "") %>')" aria-label="Delete contact">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }); %>
        <% if (contacts.length === 0) { %>
        <tr>
          <td colspan="9" class="empty-state">
            <i class="fas fa-address-book"></i>
            <span>No contacts<%= search || statusFilter !== 'all' ? ' match this filter' : ' yet — import the CSV above to get started' %>.</span>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<% if (pagination.total > 1) { %>
  <%- include('partials/pagination', { pagination, baseUrl: '/admin/early-access?status=' + statusFilter + '&search=' + encodeURIComponent(search) }) %>
<% } %>

<!-- ── Past campaigns ──────────────────────────────────────────── -->
<div class="card">
  <div class="card-header">
    <h2><i class="fas fa-clock-rotate-left"></i> Sent campaigns</h2>
  </div>
  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th>Subject</th>
          <th>Audience</th>
          <th>Recipients</th>
          <th>Sent</th>
          <th>Failed</th>
          <th>Status</th>
          <th>Date</th>
          <th>Sent by</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% campaigns.forEach(function(c) { %>
        <tr>
          <td><strong><%= c.subject %></strong></td>
          <td class="text-muted text-sm"><%= c.audience === 'selected' ? 'Selected' : 'All subscribers' %></td>
          <td><%= c.recipientCount.toLocaleString() %></td>
          <td><%= c.sentCount.toLocaleString() %></td>
          <td><%= c.failedCount > 0 ? c.failedCount.toLocaleString() : '—' %></td>
          <td>
            <%
              var cClass = 'badge-info';
              if (c.status === 'sent') cClass = 'badge-success';
              else if (c.status === 'partial') cClass = 'badge-warning';
              else if (c.status === 'failed') cClass = 'badge-danger';
            %>
            <span class="badge <%= cClass %>"><%= c.status %></span>
            <% if (c.errorSummary) { %>
              <div class="text-muted text-sm" style="margin-top:.25rem;"><%= c.errorSummary %></div>
            <% } %>
          </td>
          <td class="text-muted text-sm"><%= new Date(c.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
          <td class="text-muted text-sm"><%= c.sentByEmail %></td>
          <td>
            <button class="btn btn-sm btn-secondary"
              data-subject="<%= c.subject %>"
              data-body="<%= c.body %>"
              data-meta="<%= c.audience === 'selected' ? 'Selected contacts' : 'All subscribers' %> · <%= c.sentCount %>/<%= c.recipientCount %> delivered · <%= new Date(c.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %> · by <%= c.sentByEmail %>"
              onclick="viewCampaign(this)" aria-label="View campaign content">
              <i class="fas fa-eye"></i> View
            </button>
          </td>
        </tr>
        <% }); %>
        <% if (campaigns.length === 0) { %>
        <tr>
          <td colspan="9" class="empty-state">
            <i class="fas fa-clock-rotate-left"></i>
            <span>No campaigns sent yet.</span>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- ── Preview email modal ─────────────────────────────────────── -->
<div class="modal" id="preview-modal">
  <div class="modal-content" style="max-width:680px;">
    <div class="modal-header">
      <h2>Email preview</h2>
      <button class="modal-close" onclick="closeModal('preview-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <p class="text-muted text-sm" style="margin:0 0 .5rem;">
        Personalized with <code>firstName</code> =
        <input type="text" id="preview-first-name" value="Sarah" maxlength="80"
               style="display:inline-block;width:auto;padding:.15rem .4rem;font-size:13px;"
               onchange="renderPreview()">
        — this is exactly how Resend wraps and sends the email.
      </p>
      <div class="form-group" style="margin-bottom:.75rem;">
        <label>Subject</label>
        <p id="preview-subject" style="margin:0;font-weight:600;"></p>
      </div>
      <div class="form-group" style="margin-bottom:0;">
        <label>Body</label>
        <iframe id="preview-iframe" sandbox=""
                style="width:100%;height:520px;border:1px solid #ece8e1;border-radius:8px;background:#f4f1ec;"
                title="Email preview"></iframe>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('preview-modal')">Close</button>
    </div>
  </div>
</div>

<!-- ── Send confirmation modal ─────────────────────────────────── -->
<div class="modal" id="send-modal">
  <div class="modal-content modal-sm">
    <div class="modal-header">
      <h2>Send campaign</h2>
      <button class="modal-close" onclick="closeModal('send-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <p id="send-modal-audience">You're about to send this campaign.</p>
      <p class="text-muted text-sm">Subject: <strong id="send-modal-subject"></strong></p>
      <p class="text-muted text-sm">This cannot be undone. Sending may take up to a minute for a large list.</p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('send-modal')">Cancel</button>
      <button class="btn btn-primary" id="send-confirm-btn" onclick="sendCampaign()">Send now</button>
    </div>
  </div>
</div>

<!-- ── Add contact modal ───────────────────────────────────────── -->
<div class="modal" id="add-contact-modal">
  <div class="modal-content modal-sm">
    <div class="modal-header">
      <h2>Add someone</h2>
      <button class="modal-close" onclick="closeModal('add-contact-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <p class="text-muted text-sm" style="margin-top:0;">
        Email is required so they can receive campaigns. Name and phone are optional.
      </p>
      <div class="form-group">
        <label for="add-email">Email</label>
        <input type="email" id="add-email" placeholder="name@example.com">
      </div>
      <div class="form-group">
        <label for="add-first">First name <span class="text-muted">(optional)</span></label>
        <input type="text" id="add-first" placeholder="First name">
      </div>
      <div class="form-group">
        <label for="add-last">Last name <span class="text-muted">(optional)</span></label>
        <input type="text" id="add-last" placeholder="Last name">
      </div>
      <div class="form-group">
        <label for="add-phone">Phone <span class="text-muted">(optional)</span></label>
        <input type="tel" id="add-phone" placeholder="Phone number">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('add-contact-modal')">Cancel</button>
      <button class="btn btn-primary" id="add-contact-btn" onclick="addContactSubmit()">Add contact</button>
    </div>
  </div>
</div>

<!-- ── Edit contact modal ──────────────────────────────────────── -->
<div class="modal" id="edit-contact-modal">
  <div class="modal-content modal-sm">
    <div class="modal-header">
      <h2>Edit contact</h2>
      <button class="modal-close" onclick="closeModal('edit-contact-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-id">
      <div class="form-group">
        <label for="edit-email">Email</label>
        <input type="text" id="edit-email" placeholder="name@example.com">
        <p class="text-muted text-sm" style="margin:.25rem 0 0;">A flagged address gets the warning icon. Fix it here and the flag clears automatically.</p>
      </div>
      <div class="form-group">
        <label for="edit-first">First name <span class="text-muted">(optional)</span></label>
        <input type="text" id="edit-first">
      </div>
      <div class="form-group">
        <label for="edit-last">Last name <span class="text-muted">(optional)</span></label>
        <input type="text" id="edit-last">
      </div>
      <div class="form-group">
        <label for="edit-phone">Phone <span class="text-muted">(optional)</span></label>
        <input type="tel" id="edit-phone">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('edit-contact-modal')">Cancel</button>
      <button class="btn btn-primary" id="edit-contact-btn" onclick="saveContactEdits()">Save changes</button>
    </div>
  </div>
</div>

<!-- ── Campaign view modal ─────────────────────────────────────── -->
<div class="modal" id="campaign-modal">
  <div class="modal-content">
    <div class="modal-header">
      <h2>Campaign</h2>
      <button class="modal-close" onclick="closeModal('campaign-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label>Subject</label>
        <p id="campaign-modal-subject" style="margin:0;font-weight:600;"></p>
      </div>
      <div class="form-group">
        <label>Message</label>
        <p id="campaign-modal-body" style="margin:0;white-space:pre-wrap;"></p>
      </div>
      <p class="text-muted text-sm" id="campaign-modal-meta" style="margin:0;"></p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('campaign-modal')">Close</button>
    </div>
  </div>
</div>

<script>
  // ── Import CSV ──────────────────────────────────────────────
  document.getElementById('csv-file').addEventListener('change', function (e) {
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function () {
      document.getElementById('csv-text').value = reader.result;
      showToast('File loaded — review and click Import', 'success');
    };
    reader.onerror = function () { showToast('Could not read that file', 'error'); };
    reader.readAsText(file);
  });

  function importCsv() {
    var csv = document.getElementById('csv-text').value.trim();
    if (!csv) { showToast('Choose a CSV file or paste its contents first', 'error'); return; }
    var btn = document.getElementById('import-btn');
    btn.disabled = true;
    adminFetch('/admin/api/early-access/import', {
      method: 'POST',
      body: JSON.stringify({ csv: csv })
    }).then(function (d) {
      // Surface rows that need attention: bad-email contacts are imported but
      // flagged for review (admin can fix in place); empty-email rows had to
      // be dropped because there is nothing to key the contact by.
      var notes = [];
      if (d.flagged > 0) {
        notes.push(
          d.flagged + ' contact' + (d.flagged === 1 ? '' : 's') +
          ' imported with a flagged email address. Use the "Needs review" filter to fix them.'
        );
      }
      if (d.skippedRows && d.skippedRows.length > 0) {
        notes.push(
          'Rows dropped (no email):\n  • ' + d.skippedRows.join('\n  • ')
        );
      }
      if (notes.length > 0) alert(d.message + '\n\n' + notes.join('\n\n'));
      toastAndReload(d.message || 'Contacts imported',
        (d.flagged > 0 || d.skipped > 0) ? 'error' : 'success');
    }).catch(function (err) {
      btn.disabled = false;
      showToast(err.message, 'error');
    });
  }

  // ── Contact selection (persists across search/pagination) ───
  var SELECTION_KEY = 'chefless-early-access-selection';

  function getSelection() {
    try {
      var raw = sessionStorage.getItem(SELECTION_KEY);
      return raw ? JSON.parse(raw) : [];
    } catch (e) { return []; }
  }
  function saveSelection(ids) {
    try { sessionStorage.setItem(SELECTION_KEY, JSON.stringify(ids)); } catch (e) {}
  }

  function refreshSelectionUI() {
    var ids = getSelection();
    document.getElementById('selected-count').textContent = ids.length;
    document.getElementById('selection-bar-count').textContent = ids.length;
    document.getElementById('selection-bar').style.display = ids.length > 0 ? 'flex' : 'none';
  }

  function onContactCheck(box) {
    var ids = getSelection();
    var idx = ids.indexOf(box.value);
    if (box.checked && idx === -1) ids.push(box.value);
    else if (!box.checked && idx !== -1) ids.splice(idx, 1);
    saveSelection(ids);
    refreshSelectionUI();
  }

  function toggleSelectAll(box) {
    document.querySelectorAll('.contact-check').forEach(function (cb) {
      cb.checked = box.checked;
      onContactCheck(cb);
    });
  }

  function clearSelection() {
    saveSelection([]);
    document.querySelectorAll('.contact-check').forEach(function (cb) { cb.checked = false; });
    document.getElementById('select-all').checked = false;
    var selectedRadio = document.getElementById('audience-selected');
    if (selectedRadio.checked) {
      document.querySelector('input[name="audience"][value="all"]').checked = true;
      updateAudienceUI();
    }
    refreshSelectionUI();
  }

  function updateAudienceUI() {
    // No-op hook for future UI state; keeps the radio onchange harmless.
    refreshSelectionUI();
  }

  // Restore checkbox state for rows visible on this page.
  (function () {
    var ids = getSelection();
    document.querySelectorAll('.contact-check').forEach(function (cb) {
      cb.checked = ids.indexOf(cb.value) !== -1;
    });
    refreshSelectionUI();
  })();

  // ── Contacts ────────────────────────────────────────────────
  function toggleContact(id) {
    adminFetch('/admin/api/early-access/contacts/' + id + '/toggle', { method: 'POST' })
      .then(function (d) {
        toastAndReload('Contact ' + d.status, 'success');
      }).catch(function (err) { showToast(err.message, 'error'); });
  }

  function deleteContact(id, email) {
    if (!confirm('Permanently delete ' + email + ' from the list? This cannot be undone.')) return;
    adminFetch('/admin/api/early-access/contacts/' + id, { method: 'DELETE' })
      .then(function () {
        var row = document.getElementById('contact-row-' + id);
        if (row) row.remove();
        var ids = getSelection();
        var idx = ids.indexOf(id);
        if (idx !== -1) { ids.splice(idx, 1); saveSelection(ids); refreshSelectionUI(); }
        showToast('Contact deleted', 'success');
      }).catch(function (err) { showToast(err.message, 'error'); });
  }

  // ── Add contact ─────────────────────────────────────────────
  function addContactSubmit() {
    var email = document.getElementById('add-email').value.trim();
    if (!email) { showToast('Email is required', 'error'); return; }
    var btn = document.getElementById('add-contact-btn');
    btn.disabled = true;
    adminFetch('/admin/api/early-access/contacts', {
      method: 'POST',
      body: JSON.stringify({
        email: email,
        firstName: document.getElementById('add-first').value.trim(),
        lastName: document.getElementById('add-last').value.trim(),
        phone: document.getElementById('add-phone').value.trim()
      })
    }).then(function () {
      toastAndReload('Contact added', 'success');
    }).catch(function (err) {
      btn.disabled = false;
      showToast(err.message, 'error');
    });
  }

  // ── Edit contact ────────────────────────────────────────────
  function openEditContact(btn) {
    document.getElementById('edit-id').value = btn.getAttribute('data-id');
    document.getElementById('edit-email').value = btn.getAttribute('data-email') || '';
    document.getElementById('edit-first').value = btn.getAttribute('data-first') || '';
    document.getElementById('edit-last').value = btn.getAttribute('data-last') || '';
    document.getElementById('edit-phone').value = btn.getAttribute('data-phone') || '';
    openModal('edit-contact-modal');
  }

  function saveContactEdits() {
    var id = document.getElementById('edit-id').value;
    if (!id) return;
    var btn = document.getElementById('edit-contact-btn');
    btn.disabled = true;
    adminFetch('/admin/api/early-access/contacts/' + id, {
      method: 'PATCH',
      body: JSON.stringify({
        email: document.getElementById('edit-email').value,
        firstName: document.getElementById('edit-first').value,
        lastName: document.getElementById('edit-last').value,
        phone: document.getElementById('edit-phone').value
      })
    }).then(function () {
      toastAndReload('Contact updated', 'success');
    }).catch(function (err) {
      btn.disabled = false;
      showToast(err.message, 'error');
    });
  }

  // ── Campaign history ────────────────────────────────────────
  function viewCampaign(btn) {
    document.getElementById('campaign-modal-subject').textContent = btn.getAttribute('data-subject');
    document.getElementById('campaign-modal-body').textContent = btn.getAttribute('data-body');
    document.getElementById('campaign-modal-meta').textContent = btn.getAttribute('data-meta');
    openModal('campaign-modal');
  }

  // ── Send campaign ───────────────────────────────────────────
  function selectedAudience() {
    var checked = document.querySelector('input[name="audience"]:checked');
    return checked ? checked.value : 'all';
  }

  function openPreviewModal() {
    var subject = document.getElementById('campaign-subject').value.trim();
    var body = document.getElementById('campaign-body').value.trim();
    if (!subject) { showToast('Add a subject first', 'error'); return; }
    if (!body) { showToast('Add a message body first', 'error'); return; }
    openModal('preview-modal');
    renderPreview();
  }

  function renderPreview() {
    var subject = document.getElementById('campaign-subject').value.trim();
    var body = document.getElementById('campaign-body').value.trim();
    if (!subject || !body) return;
    var firstName = document.getElementById('preview-first-name').value.trim();
    var iframe = document.getElementById('preview-iframe');
    var subjectEl = document.getElementById('preview-subject');
    subjectEl.textContent = 'Loading…';
    iframe.srcdoc = '';
    adminFetch('/admin/api/early-access/preview', {
      method: 'POST',
      body: JSON.stringify({ subject: subject, body: body, firstName: firstName })
    }).then(function (d) {
      subjectEl.textContent = d.subject;
      iframe.srcdoc = d.html;
    }).catch(function (err) {
      subjectEl.textContent = '';
      iframe.srcdoc = '';
      showToast(err.message, 'error');
    });
  }

  function openSendModal() {
    var subject = document.getElementById('campaign-subject').value.trim();
    var body = document.getElementById('campaign-body').value.trim();
    if (!subject) { showToast('Add a subject first', 'error'); return; }
    if (!body) { showToast('Add a message body first', 'error'); return; }

    var audience = selectedAudience();
    var msg;
    if (audience === 'selected') {
      var count = getSelection().length;
      if (count === 0) {
        showToast('Pick contacts in the table first, or choose "All subscribed"', 'error');
        return;
      }
      msg = "You're about to email " + count + ' selected contact' + (count === 1 ? '' : 's') +
            '. Unsubscribed contacts are skipped automatically.';
    } else {
      msg = "You're about to email all subscribed contacts on the list.";
    }
    document.getElementById('send-modal-audience').textContent = msg;
    document.getElementById('send-modal-subject').textContent = subject;
    openModal('send-modal');
  }

  function sendCampaign() {
    var subject = document.getElementById('campaign-subject').value.trim();
    var body = document.getElementById('campaign-body').value.trim();
    var audience = selectedAudience();
    var payload = { subject: subject, body: body };
    if (audience === 'selected') payload.contactIds = getSelection();

    var btn = document.getElementById('send-confirm-btn');
    btn.disabled = true;
    btn.textContent = 'Sending…';
    adminFetch('/admin/api/early-access/send', {
      method: 'POST',
      body: JSON.stringify(payload)
    }).then(function (d) {
      var msg = 'Sent ' + d.sentCount + ' email' + (d.sentCount === 1 ? '' : 's');
      if (d.failedCount > 0) msg += ' · ' + d.failedCount + ' failed';
      if (audience === 'selected') saveSelection([]);
      toastAndReload(msg, d.failedCount > 0 ? 'error' : 'success');
    }).catch(function (err) {
      btn.disabled = false;
      btn.textContent = 'Send now';
      closeModal('send-modal');
      showToast(err.message, 'error');
    });
  }
</script>
